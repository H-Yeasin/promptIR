{
  "name": "promptir",
  "displayName": "PromptIR",
  "description": "Optimizes raw developer prompts using native AI models.",
  "version": "0.0.2",
  "publisher": "habibUllahYeasin",
  "author": {
    "name": "HabibUllah Yeasin",
    "email": "habibullahyeasin.dev@gmail.com"
  },
  "license": "MIT",
  "icon": "media/promptir-logo.png",
  "galleryBanner": {
    "color": "#181A1F",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/H-Yeasin/promptIR.git"
  },
  "bugs": {
    "url": "https://github.com/H-Yeasin/promptIR/issues"
  },
  "homepage": "https://github.com/H-Yeasin/promptIR#readme",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "prompt",
    "prompt-engineering",
    "ai",
    "copilot",
    "codex",
    "developer-tools",
    "productivity",
    "context"
  ],
  "pricing": "Free",
  "activationEvents": [
    "onCommand:promptir.optimize",
    "onCommand:promptir.openSidebar",
    "onCommand:promptir.copyToClipboard",
    "onChatParticipant:promptir.chat",
    "onView:promptir.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptir.optimize",
        "title": "PromptIR: Optimize Prompt with Context",
        "icon": {
          "light": "media/promptir-logo.svg",
          "dark": "media/promptir-logo.svg"
        }
      },
      {
        "command": "promptir.copyToClipboard",
        "title": "PromptIR: Copy Optimized Prompt"
      },
      {
        "command": "promptir.openSidebar",
        "title": "PromptIR: Open Chatbox",
        "icon": {
          "light": "media/promptir-logo.svg",
          "dark": "media/promptir-logo.svg"
        }
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "promptir",
          "title": "PromptIR",
          "icon": "media/promptir-logo.svg"
        }
      ]
    },
    "views": {
      "promptir": [
        {
          "id": "promptir.sidebar",
          "name": "PromptIR",
          "icon": "media/promptir-logo.svg",
          "type": "webview"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "promptir.chat",
        "name": "promptir",
        "fullName": "PromptIR",
        "description": "Optimize raw coding prompts with active editor context.",
        "isSticky": true,
        "commands": [
          {
            "name": "optimize",
            "description": "Optimize a raw prompt using the active editor context."
          },
          {
            "name": "review",
            "description": "Prepare a bug-review prompt using the active editor context."
          },
          {
            "name": "explain",
            "description": "Prepare an explanation prompt for the active file or selection."
          },
          {
            "name": "problems",
            "description": "Prepare a prompt focused on current VS Code Problems diagnostics."
          },
          {
            "name": "plan",
            "description": "Prepare a planning-only prompt without asking for code edits."
          }
        ]
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "promptir.optimize",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "PromptIR",
      "properties": {
        "promptir.aiProvider": {
          "type": "string",
          "enum": [
            "Copilot",
            "OpenAI"
          ],
          "default": "Copilot",
          "description": "Select the AI provider to use. 'Copilot' uses the native VS Code LM API. 'OpenAI' uses a custom API key."
        },
        "promptir.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "Your OpenAI API key (if using OpenAI provider). Leave blank to use Copilot."
        },
        "promptir.openaiModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "The OpenAI model to use (e.g., gpt-4o, gpt-4o-mini)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "openai": "^6.45.0"
  }
}
